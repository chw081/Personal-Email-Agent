DATABASE_URL=sqlite:///./dev.db
OPENAI_API_KEY=your_openai_key_here
# Paths are relative to backend/ when running uvicorn from backend/
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
ANALYSIS_PROVIDER=rule_based
# Comma-separated extra origins for CORS (e.g. your deployed frontend URL)
# CORS_EXTRA_ORIGINS=https://your-app.vercel.app